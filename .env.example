# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Waitlist gate code (users must enter this to reach login/signup)
WAITLIST_CODE=""

# Admin passcode (for passcode-based admin login on waitlist page)
ADMIN_PASSCODE=""

# Portal access code (for portal entry — must differ from ADMIN_PASSCODE)
PORTAL_ACCESS_CODE=""

# Together AI (Level 1 generation + embeddings + chat)
TOGETHER_API_KEY=""
# Optional: override the Together AI chat model (default: deepseek-ai/DeepSeek-R1)
# TOGETHER_CHAT_MODEL=""

# Anthropic (Level 2 generation)
ANTHROPIC_API_KEY=""

# Vercel Blob (file uploads)
BLOB_READ_WRITE_TOKEN=""

# Stripe (Level 2 payments)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID=""

# Root env for Convex CLI and backend auth validation

# Convex deployment settings
CONVEX_DEPLOYMENT=dev:your-convex-deployment
CONVEX_URL=https://your-project.convex.cloud
CONVEX_SITE_URL=https://your-project.convex.site

# Clerk + Convex
# Copy this from https://dashboard.clerk.com/apps/setup/convex
# Example format (dev): https://your-app-name.clerk.accounts.dev
# Example format (prod): https://clerk.your-domain.com
CLERK_JWT_ISSUER_DOMAIN=

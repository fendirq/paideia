# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Waitlist gate code (users must enter this to reach login/signup)
WAITLIST_CODE=""

# Admin passcode (for passcode-based admin login on waitlist page)
ADMIN_PASSCODE=""

# Portal access code (for portal entry — must differ from ADMIN_PASSCODE)
PORTAL_ACCESS_CODE=""

# Together AI (Level 1 generation + embeddings + chat)
TOGETHER_API_KEY=""
# Optional: override the Level 1 generation model on Together AI
# (default: deepseek-ai/DeepSeek-V3). Swap to a Moonshot Kimi checkpoint
# for longer-context assignments, e.g. moonshotai/Kimi-K2-Instruct-0905.
# LEVEL1_MODEL=""
# Optional: override the Together AI chat model (separate from generation)
# TOGETHER_CHAT_MODEL=""

# Level 2 provider — "gemini" (default) or "anthropic"
LEVEL2_PROVIDER="gemini"

# Gemini (Level 2 generation + tutor chat — both use this key)
GEMINI_API_KEY=""
# Optional: override the Level 2 essay-generation Gemini models
# LEVEL2_GEMINI_MODEL="gemini-3.1-pro-preview"
# LEVEL2_GEMINI_FALLBACK_MODEL="gemini-3-pro-preview"
# Optional: override the tutor chat model. Default is
# gemini-3-flash-preview with thinking disabled (thinkingBudget:0) —
# stronger reasoning than 2.5-flash at the same first-token latency.
# Upgrade to a pro/thinking model for deeper reasoning at the cost
# of seconds-per-response thinking overhead.
# GEMINI_CHAT_MODEL="gemini-3-flash-preview"

# Anthropic (Level 2 fallback / dormant — only required when
# LEVEL2_PROVIDER="anthropic"). Leave unset if using Gemini.
ANTHROPIC_API_KEY=""
# Optional Anthropic model overrides (only honored when provider=anthropic):
# ANTHROPIC_LEVEL2_PRIMARY_MODEL="claude-opus-4-6"
# ANTHROPIC_LEVEL2_FALLBACK_MODEL="claude-sonnet-4-6"
# ANTHROPIC_MODEL=""

# Vercel Blob (file uploads)
BLOB_READ_WRITE_TOKEN=""

# Stripe (Level 2 payments)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID=""

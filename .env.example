# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Admin passcode (for passcode-based admin login at /login)
ADMIN_PASSCODE=""

# Portal access code (for portal entry — must differ from ADMIN_PASSCODE)
PORTAL_ACCESS_CODE=""

# Together AI (Level 1 essay generation + embeddings). Tutor chat
# migrated to Gemini — see GEMINI_CHAT_MODEL below.
TOGETHER_API_KEY=""
# Optional: override the Level 1 generation model on Together AI
# (default: deepseek-ai/DeepSeek-V3). Swap to a Moonshot Kimi checkpoint
# for longer-context assignments, e.g. moonshotai/Kimi-K2-Instruct-0905.
# LEVEL1_MODEL=""

# Level 2 provider — "gemini" (default) or "anthropic"
LEVEL2_PROVIDER="gemini"

# Gemini (Level 2 generation + tutor chat — both use this key)
GEMINI_API_KEY=""
# Optional: override the Level 2 essay-generation Gemini models
# LEVEL2_GEMINI_MODEL="gemini-3.1-pro-preview"
# LEVEL2_GEMINI_FALLBACK_MODEL="gemini-3-pro-preview"
# Optional: override the tutor chat models. Primary defaults to
# gemini-3-flash-preview with thinking disabled (thinkingBudget:0) —
# stronger reasoning than 2.5-flash at the same first-token latency.
# Fallback defaults to gemini-2.5-flash (GA, stable) — fires when
# the primary returns a retryable error (4xx/5xx/network/timeout)
# BEFORE any tokens stream. Set FALLBACK equal to the primary (or
# remove it) to disable the fallback pathway.
# GEMINI_CHAT_MODEL="gemini-3-flash-preview"
# GEMINI_CHAT_FALLBACK_MODEL="gemini-2.5-flash"

# Material-structure detection (see src/lib/material-structure.ts).
# When "true", uploaded File + ClassMaterialFile rows get classified
# (reading_with_questions / worksheet / problem_set / etc.) on
# upload. Off by default so shipping the wiring is independent
# from flipping the detection cost live; flip ON after you've run
# scripts/backfill-material-structure.ts on existing rows.
#
# WRITE-TIME ONLY. The chat-route read-side intentionally does not
# consult this flag: any row with structure populated drives the
# tutor prompt regardless. Flipping this OFF stops new classification
# but does NOT suppress structure already stored from a previous
# flag-on period or the backfill script.
# ENABLE_MATERIAL_STRUCTURE="true"
# Optional: override the detection model (default:
# gemini-3-flash-preview — same as the tutor).
# MATERIAL_STRUCTURE_MODEL="gemini-3-flash-preview"

# Anthropic (Level 2 fallback / dormant — only required when
# LEVEL2_PROVIDER="anthropic"). Leave unset if using Gemini.
ANTHROPIC_API_KEY=""
# Optional Anthropic model overrides (only honored when provider=anthropic):
# ANTHROPIC_LEVEL2_PRIMARY_MODEL="claude-opus-4-6"
# ANTHROPIC_LEVEL2_FALLBACK_MODEL="claude-sonnet-4-6"
# ANTHROPIC_MODEL=""

# Vercel Blob (file uploads)
BLOB_READ_WRITE_TOKEN=""

# Stripe (Level 2 payments)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID=""

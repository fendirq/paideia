generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

// ─── Enums ───

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum Subject {
  MATHEMATICS
  ENGLISH
  HISTORY
  SCIENCE
  MANDARIN
  HUMANITIES
  OTHER
}

enum SessionStatus {
  ACTIVE
  COMPLETED
}

enum StudyStatus {
  NEW
  REVIEW
  PRACTICED
}

// ─── NextAuth Models ───

model User {
  id               String            @id @default(cuid())
  name             String?
  email            String            @unique
  emailVerified    DateTime?
  image            String?
  role             Role?
  phone            String?           @unique
  passwordHash     String?
  school           String?
  grade            String?
  subjectsTaught   Subject[]
  level2PaidAt     DateTime?
  stripePaymentId  String?           @unique
  stripeCustomerId String?           @unique
  accounts         Account[]
  inquiries        Inquiry[]
  tutoringSessions TutoringSession[]
  teacherClasses   Class[]           @relation("teacherClasses")
  enrollments      ClassEnrollment[] @relation("studentEnrollments")
  writingProfile   WritingProfile?
  writingSamples   WritingSample[]
  generatedEssays  GeneratedEssay[]
  portalClasses    PortalClass[]
  createdAt        DateTime          @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// ─── App Models ───

model Inquiry {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id])
  subject     Subject
  teacherName String
  unitName    String
  description  String
  teacherNotes String?
  classId     String?
  class       Class?            @relation(fields: [classId], references: [id])
  files        File[]
  chunks      TextChunk[]
  sessions    TutoringSession[]
  exams       Exam[]
  studyItems  StudyItem[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model File {
  id                    String      @id @default(cuid())
  inquiryId             String
  inquiry               Inquiry     @relation(fields: [inquiryId], references: [id])
  fileName              String
  fileUrl               String
  fileType              String
  extractedText         String?
  chunks                TextChunk[]
  createdAt             DateTime    @default(now())
  // Material-structure detection (see src/lib/material-structure.ts).
  // Populated once at upload; used by the tutor system prompt to
  // adapt output format (question numbering, walkthrough vs Socratic).
  // Nullable so uploads never block on detection failure.
  structureKind         String?
  structure             Json?
  structureExtractedAt  DateTime?
  structureModel        String?
}

model TextChunk {
  id         String                      @id @default(cuid())
  fileId     String
  file       File                        @relation(fields: [fileId], references: [id])
  inquiryId  String
  inquiry    Inquiry                     @relation(fields: [inquiryId], references: [id])
  content    String
  embedding  Unsupported("vector(1024)")
  chunkIndex Int
  createdAt  DateTime                    @default(now())
}

model TutoringSession {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id])
  inquiryId     String?
  inquiry       Inquiry?       @relation(fields: [inquiryId], references: [id])
  classId       String?
  class         Class?         @relation(fields: [classId], references: [id])
  materialId    String?
  material      ClassMaterial? @relation("materialSessions", fields: [materialId], references: [id])
  helpType      String?
  summary       String?
  messages      Message[]
  rating        Int?
  ratingComment String?
  status        SessionStatus  @default(ACTIVE)
  duration      Int?
  startedAt     DateTime       @default(now())
  endedAt       DateTime?
}

model Message {
  id               String          @id @default(cuid())
  sessionId        String
  session          TutoringSession @relation(fields: [sessionId], references: [id])
  role             String
  content          String
  suggestedActions String[]
  createdAt        DateTime        @default(now())
}

model Report {
  id         String   @id @default(cuid())
  reporterId String
  targetType String
  targetId   String
  reason     String
  status     String   @default("pending")
  createdAt  DateTime @default(now())
}

model Exam {
  id         String      @id @default(cuid())
  inquiryId  String
  inquiry    Inquiry     @relation(fields: [inquiryId], references: [id])
  name       String
  date       DateTime
  topics     String[]
  studyItems StudyItem[]
  createdAt  DateTime    @default(now())
}

model StudyItem {
  id        String      @id @default(cuid())
  inquiryId String
  inquiry   Inquiry     @relation(fields: [inquiryId], references: [id])
  examId    String?
  exam      Exam?       @relation(fields: [examId], references: [id])
  topic     String
  chapter   String?
  status    StudyStatus @default(NEW)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

// ─── Class Models ───

model Class {
  id          String            @id @default(cuid())
  teacherId   String
  teacher     User              @relation("teacherClasses", fields: [teacherId], references: [id])
  name        String
  subject     Subject
  description String?
  period      Int?
  pinnedNote  String?
  joinCode    String            @unique
  enrollments ClassEnrollment[]
  sessions    TutoringSession[]
  inquiries   Inquiry[]
  materials   ClassMaterial[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model ClassEnrollment {
  id            String    @id @default(cuid())
  classId       String
  class         Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  studentId     String
  student       User      @relation("studentEnrollments", fields: [studentId], references: [id])
  joinedAt      DateTime  @default(now())
  lastVisitedAt DateTime?

  @@unique([classId, studentId])
}

// ─── Class Material Models ───

model ClassMaterial {
  id          String              @id @default(cuid())
  classId     String
  class       Class               @relation(fields: [classId], references: [id], onDelete: Cascade)
  title       String
  description String
  dueDate     DateTime?
  files       ClassMaterialFile[]
  chunks      MaterialChunk[]
  sessions    TutoringSession[]   @relation("materialSessions")
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model ClassMaterialFile {
  id                    String         @id @default(cuid())
  materialId            String
  material              ClassMaterial  @relation(fields: [materialId], references: [id], onDelete: Cascade)
  fileName              String
  fileUrl               String
  fileType              String
  extractedText         String?
  chunks                MaterialChunk[]
  createdAt             DateTime       @default(now())
  // Material-structure detection — see File model for usage.
  structureKind         String?
  structure             Json?
  structureExtractedAt  DateTime?
  structureModel        String?
}

model MaterialChunk {
  id         String                      @id @default(cuid())
  fileId     String
  file       ClassMaterialFile           @relation(fields: [fileId], references: [id], onDelete: Cascade)
  materialId String
  material   ClassMaterial               @relation(fields: [materialId], references: [id], onDelete: Cascade)
  content    String
  embedding  Unsupported("vector(1024)")
  chunkIndex Int
  createdAt  DateTime                    @default(now())
}

// ─── Portal Models ───

model WritingProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  level            Int      @default(1)
  teacherProfile   Json
  selfAssessment   Json
  writingStyle     Json?
  styleFingerprint Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model WritingSample {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String
  content   String
  wordCount Int
  createdAt DateTime @default(now())
}

model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model GeneratedEssay {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  portalClassId String?
  portalClass   PortalClass? @relation(fields: [portalClassId], references: [id], onDelete: SetNull)
  subject       String
  assignment    String
  requirements  String?
  level         Int
  essay         String
  wordCount     Int
  createdAt     DateTime     @default(now())
}

model PortalClass {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  subject   Subject
  essays    GeneratedEssay[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model StripeWebhookEvent {
  id          String   @id
  eventType   String
  processedAt DateTime @default(now())
}

model RateLimit {
  id          String   @id
  windowStart DateTime
  count       Int
  updatedAt   DateTime @default(now())

  @@index([windowStart])
}
